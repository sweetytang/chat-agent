{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "../../*"
            ],
            "@common/*": [
                "./common/*"
            ],
            "@frontend/*": [
                "./frontend/*"
            ],
            "@backend/*": [
                "./backend/*"
            ]
        },
        "outDir": "./dist",
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "frontend/**/*",
        "backend/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}