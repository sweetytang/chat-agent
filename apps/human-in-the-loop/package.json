{
  "name": "human-in-the-loop",
  "version": "1.0.0",
  "description": "LangChain human-in-the-loop demo",
  "type": "module",
  "scripts": {
    "start": "pnpm run dev:server & pnpm run dev",
    "dev": "vite",
    "db:push": "prisma db push --config ../../prisma.config.ts",
    "prisma:generate": "prisma generate --config ../../prisma.config.ts",
    "dev:server": "pnpm run db:push && tsx --watch src/backend/server.ts",
    "build": "pnpm run prisma:generate && tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}