{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": "../../",
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "outDir": "./dist",
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "src/**/*",
        "pages/**/*",
        "utils/**/*",
        "tests/**/*",
        "scripts/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}