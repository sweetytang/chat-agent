generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  userId       String    @id @default(uuid()) @map("user_id")
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  sessions     Session[]
  threads      Thread[]

  @@map("users")
}

model Session {
  token     String   @id @default(uuid())
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([expiresAt], map: "idx_sessions_expires_at")
  @@index([userId], map: "idx_sessions_user_id")
  @@map("sessions")
}

model Thread {
  threadId           String             @id @map("thread_id")
  userId             String?            @map("user_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  metadataJson       String             @map("metadata_json")
  status             String
  valuesJson         String             @map("values_json")
  latestCheckpointId String?            @map("latest_checkpoint_id")
  user               User?              @relation(fields: [userId], references: [userId], onDelete: Cascade)
  checkpoints        ThreadCheckpoint[]
  interrupt          Interrupt?

  @@index([userId, updatedAt], map: "idx_threads_user_id_updated_at")
  @@map("threads")
}

model ThreadCheckpoint {
  checkpointId String   @id @map("checkpoint_id")
  threadId     String   @map("thread_id")
  createdAt    DateTime @default(now()) @map("created_at")
  status       String
  metadataJson String   @map("metadata_json")
  valuesJson   String   @map("values_json")
  thread       Thread   @relation(fields: [threadId], references: [threadId], onDelete: Cascade)

  @@index([threadId, createdAt], map: "idx_thread_checkpoints_thread_created_at")
  @@map("thread_checkpoints")
}

model Interrupt {
  threadId        String   @id @map("thread_id")
  requestId       String   @map("request_id")
  checkpointId    String?  @map("checkpoint_id")
  hitlRequestJson String   @map("hitl_request_json")
  aiMessageJson   String   @map("ai_message_json")
  allMessagesJson String   @map("all_messages_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  thread          Thread   @relation(fields: [threadId], references: [threadId], onDelete: Cascade)

  @@map("interrupts")
}
