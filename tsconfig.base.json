{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    // === 基础编译目标 ===
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    // === 模块解析 ===
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    // === 严格类型检查 ===
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    // === 其他优化与规范 ===
    "skipLibCheck": true, // 跳过 node_modules 中的类型检查，极大提升编译速度
    "forceConsistentCasingInFileNames": true, // 强制文件名大小写一致
    "isolatedModules": true, // 确保每个文件都能安全地进行单文件转译
    "declaration": true // 为子包自动生成 .d.ts 声明文件（Monorepo 必备）
  },
  // 根目录的配置本身不应该去编译任何具体代码
  "exclude": [
    "node_modules",
    "dist",
    "packages/**/dist",
    "apps/**/dist"
  ]
}